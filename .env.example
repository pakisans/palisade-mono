# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://appuser:apppassword@postgres:5432/palisade
DATABASE_URL_BUILD=postgresql://appuser:apppassword@localhost:5433/palisade

# ── Payload CMS ───────────────────────────────────────────────────────────────
PAYLOAD_SECRET=change-me-to-a-random-secret
PREVIEW_SECRET=change-me-to-a-random-preview-secret

# ── URLs ──────────────────────────────────────────────────────────────────────
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001
NEXT_PUBLIC_PAYLOAD_URL=http://localhost:3001
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
PAYLOAD_URL_BUILD=http://backend:3000

# ── SEO / Indeksiranje ────────────────────────────────────────────────────────
# Javni URL frontenda — koristi se za canonical, sitemap, OG i JSON-LD.
NEXT_PUBLIC_SITE_URL=https://palisada.rs
NEXT_PUBLIC_SITE_NAME=Palisada d.o.o.
# Dozvola indeksiranja. Ostaviti PRAZNO/false na privremenom (staging) domenu →
# ceo sajt je noindex,nofollow + robots.txt blokira sve. Na pravom domenu: true.
NEXT_PUBLIC_ALLOW_INDEXING=false

# ── Revalidation ──────────────────────────────────────────────────────────────
REVALIDATE_SECRET=change-me-to-a-random-revalidate-secret

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOKS_SIGNING_SECRET=whsec_...
